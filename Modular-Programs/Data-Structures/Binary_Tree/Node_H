/**
 * @file Node.h
 * @brief Definition of the Node structure used in the Binary Search Tree.
 * 
 * This structure represents a single node in the tree, storing:
 * - A data value
 * - A pointer to the left child
 * - A pointer to the right child
 */

#ifndef NODE_H
#define NODE_H

/**
 * @brief Template structure for a tree node.
 * 
 * @tparam T Data type stored in the node.
 */
template<class T>
struct Node{

private:
    T data;              ///< Value stored in the node
    Node<T>* left;       ///< Pointer to the left child
    Node<T>* right;      ///< Pointer to the right child

public:
    /**
     * @brief Constructs a new Node object.
     * 
     * @param value Value to initialize the node with.
     */
    Node(T value){
        data = value;
        left = nullptr;
        right = nullptr;
    }

    /**
     * @brief Gets the value stored in the node.
     * 
     * @return T Node data.
     */
    T getData(){
        return data;
    }

    /**
     * @brief Sets the value of the node.
     * 
     * @param value New value to assign.
     */
    void setData(T value){
        data = value;
    }

    /**
     * @brief Gets the left child node.
     * 
     * @return Node<T>* Pointer to left child.
     */
    Node<T>* getLeft(){
        return left;
    }

    /**
     * @brief Sets the left child node.
     * 
     * @param newLeft Pointer to the new left child.
     */
    void setLeft(Node<T>* newLeft){
        left = newLeft;
    }

    /**
     * @brief Gets the right child node.
     * 
     * @return Node<T>* Pointer to right child.
     */
    Node<T>* getRight(){
        return right;
    }

    /**
     * @brief Sets the right child node.
     * 
     * @param newRight Pointer to the new right child.
     */
    void setRight(Node<T>* newRight){
        right = newRight;
    }
};

#endif
